# Scout Agent — environment variables
# Copy to .env and fill in your values.

# Scout API
SCOUT_URL=https://scout.kafu.kz
SCOUT_AGENT_EMAIL=agent@scout.local
SCOUT_AGENT_PASSWORD=<CHANGE-ME>

# Anthropic API key (required for Claude Code)
ANTHROPIC_API_KEY=<CHANGE-ME>

# GitHub token (required for creating PRs)
GITHUB_TOKEN=<CHANGE-ME>

# Polling interval in seconds (0 = single run, useful for testing)
POLL_INTERVAL=300

# Max fix attempts per bug
MAX_ATTEMPTS=3
