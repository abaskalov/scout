SCOUT_PORT=10009
SCOUT_JWT_SECRET=dev-secret-change-in-production
SCOUT_DB_PATH=data/scout.db

# Production: comma-separated list of allowed CORS origins
# SCOUT_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Production: initial admin credentials (used only when users table is empty)
# SCOUT_ADMIN_EMAIL=admin@yourcompany.com
# SCOUT_ADMIN_PASSWORD=<CHANGE-ME-strong-password>
