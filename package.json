{
  "name": "scout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:all": "concurrently -n api,dash,widget \"pnpm dev\" \"pnpm --filter scout-dashboard dev\" \"pnpm --filter scout-widget build:watch\"",
    "orchestrator": "tsx orchestrator/process-bugs.ts",
    "build": "pnpm build:server && pnpm --filter scout-dashboard build && pnpm --filter scout-widget build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "deploy:prod": "./scripts/deploy.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/zod-validator": "^0.4",
    "@sentry/node": "^10.45.0",
    "bcryptjs": "^2",
    "better-sqlite3": "^11",
    "drizzle-orm": "^0.38",
    "hono": "^4",
    "jsonwebtoken": "^9",
    "nodemailer": "^8.0.3",
    "pino": "^10.3.1",
    "zod": "^3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2",
    "@types/better-sqlite3": "^7",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^22",
    "@types/nodemailer": "^7.0.11",
    "concurrently": "^9",
    "drizzle-kit": "^0.30",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
